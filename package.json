{
  "name": "@julianobazzi/utils",
  "version": "1.0.0",
  "description": "A collection of small, tree-shakeable TypeScript utility functions.",
  "type": "module",
  "license": "MIT",
  "author": "Juliano Bazzi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/julianobazzi/utils.git"
  },
  "homepage": "https://github.com/julianobazzi/utils#readme",
  "bugs": {
    "url": "https://github.com/julianobazzi/utils/issues"
  },
  "keywords": [
    "utils",
    "typescript",
    "helpers",
    "utilities"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.6.0",
  "dependencies": {
    "dayjs": "1.11.21"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "release": "changeset publish",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@changesets/cli": "2.31.0",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
